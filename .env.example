# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# L2 RPC endpoint (Polygon zkEVM / Starknet)
RPC_URL=https://your-l2-rpc-endpoint

# Deployer wallet private key (hex, 0x-prefixed) — for contract deployment only
DEPLOYER_PRIVATE_KEY=0x...

# Aggregator node settings
AGGREGATOR_HOST=0.0.0.0
AGGREGATOR_PORT=8080

# Batch settings (override defaults)
MAX_BATCH_SIZE=3000
BATCH_TIMEOUT_S=10
